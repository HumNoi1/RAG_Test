# Qdrant settings
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_demo

# Embedding model (multilingual รองรับทั้งไทยและ ENG)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# OpenAI (optional - ใช้สำหรับ LLM response ใน /query/rag)
# หากไม่มี key จะ return เฉพาะ retrieved chunks
OPENAI_API_KEY=

# Chunking settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5

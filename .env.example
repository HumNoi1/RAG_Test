# Qdrant settings
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_demo_bge_m3

# Embedding model (multilingual รองรับทั้งไทยและ ENG)
EMBEDDING_MODEL=BAAI/bge-m3

# Groq (optional - ใช้สำหรับ LLM response ใน /query/rag)
# หากไม่มี key จะ return เฉพาะ retrieved chunks
LLM_MODEL=qwen/qwen3-32b
GROQ_API_KEY=

# Chunking settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
